# =============================================================================
# Project-specific
# =============================================================================

# Runtime user uploads + per-document extracted data (~300MB).
# This directory is created and managed by the FastAPI backend at runtime.
storage/

# PDFs at the repo root are typically test fixtures with personal data.
# If you have a sanitized fixture you want to commit, name it sample*.pdf
# and the unignore rule below will let it through.
/*.pdf
!/sample*.pdf

# Local Claude Code configuration (agent definitions, hooks, etc.).
# Remove this line if you want to share agent configuration with the team.
.claude/

# Generated fontlib outputs derived from macOS system fonts.
# These are produced by `api/scripts/build_fontlib.py` and contain
# Microsoft-licensed fonts that are NOT redistributable. Regenerate after
# cloning. The vendor/ subdirectory IS committed and is safe.
api/fontlib/*.ttf
api/fontlib/*.woff2
api/fontlib/index.json
!api/fontlib/INTER-OFL.txt
!api/fontlib/vendor/
# Inter is SIL OFL 1.1 — safe to commit even though it lives at top level.
!api/fontlib/inter-*.ttf
!api/fontlib/inter-*.woff2

# Local plan / scratch notes
PLAN.md
